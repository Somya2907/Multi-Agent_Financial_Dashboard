# SEC EDGAR (no API key needed, just identification)
SEC_USER_AGENT="Your Name your@email.edu"

# Financial Modeling Prep
FMP_API_KEY=your_fmp_api_key_here

# OpenAI via CMU AI Gateway (LiteLLM proxy)
OPENAI_API_KEY=your_cmu_api_key_here
